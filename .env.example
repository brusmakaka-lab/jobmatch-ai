DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/jobmatch?sslmode=require"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# local keeps the deterministic demo analyzer. openai uses OpenAICareerAIService.
CAREER_AI_PROVIDER="local"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Demo auth is enabled automatically in local development.
# In production, leave this false and replace the cookie seam in src/proxy.ts
# with Auth.js, Clerk, or your production auth provider.
DEMO_AUTH_ENABLED="false"
DEMO_PUBLIC_ACCESS="false"
